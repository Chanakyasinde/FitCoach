# Server Configuration
PORT=3001

# Database - Supabase (Required for Workout Logging)
# Use the 'Transaction' or 'Session' connection string from Supabase Settings
DATABASE_URL=your_supabase_postgres_connection_string_here

# Supabase Client Credentials (Required for direct DB interaction or Auth)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Integration - Google Gemini (Primary for this project)
# This key is required for the "Motivational Nudge" and "Q&A Chatbot"
GEMINI_API_KEY=your_gemini_api_key_here

# Security (Optional but recommended for evaluation)
# Allows your React frontend to communicate with this Node backend
CORS_ORIGIN=http://localhost:5173